# Copie para .env ou .env.local: cp .env.example .env.local
# Gere AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# Banco (Docker local — ajuste se usar Supabase)
DATABASE_URL="postgresql://estetica:estetica@localhost:5432/estetica"

# Obrigatório para login (NextAuth / Auth.js)
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# Em produção (Vercel): mesmo valor que NEXTAUTH_URL, ex.: https://seu-app.vercel.app
# AUTH_URL=""

# Opcional: Supabase Storage (fotos)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Opcional: WhatsApp na página de contato
# NEXT_PUBLIC_ADMIN_WHATSAPP=5511999999999
